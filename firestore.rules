rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isCreatingOwnDoc() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !('field' in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser() {
      return hasRequiredFields(['uid', 'name', 'email', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             isValidString('name', 1, 100) &&
             isValidString('email', 5, 100) &&
             isValidOptionalString('businessName', 0, 100) &&
             isValidOptionalString('gstNumber', 0, 50) &&
             isValidOptionalString('phone', 0, 20);
    }

    function isValidProduct() {
      return hasRequiredFields(['userId', 'name', 'purchasePrice', 'sellingPrice', 'stockQuantity', 'createdAt']) &&
             isCreatingOwnDoc() &&
             isValidString('name', 1, 100) &&
             isValidOptionalString('category', 0, 50) &&
             request.resource.data.purchasePrice is number &&
             request.resource.data.sellingPrice is number &&
             request.resource.data.stockQuantity is number;
    }

    function isValidParty() {
      return hasRequiredFields(['userId', 'name', 'type', 'balance', 'createdAt']) &&
             isCreatingOwnDoc() &&
             isValidString('name', 1, 100) &&
             isValidOptionalString('mobile', 0, 20) &&
             isValidOptionalString('address', 0, 200) &&
             request.resource.data.type in ['customer', 'supplier'] &&
             request.resource.data.balance is number;
    }

    function isValidSale() {
      return hasRequiredFields(['userId', 'totalAmount', 'finalAmount', 'paymentMode', 'items', 'date', 'createdAt']) &&
             isCreatingOwnDoc() &&
             request.resource.data.totalAmount is number &&
             request.resource.data.finalAmount is number &&
             request.resource.data.paymentMode in ['cash', 'upi', 'bank', 'credit'] &&
             request.resource.data.items is list &&
             request.resource.data.items.size() <= 100 &&
             isValidOptionalString('partyId', 0, 50) &&
             isValidOptionalString('partyName', 0, 100);
    }

    function isValidExpense() {
      return hasRequiredFields(['userId', 'category', 'amount', 'paymentMode', 'date', 'createdAt']) &&
             isCreatingOwnDoc() &&
             isValidString('category', 1, 50) &&
             request.resource.data.amount is number &&
             request.resource.data.paymentMode in ['cash', 'upi', 'bank'] &&
             isValidOptionalString('description', 0, 500);
    }

    function isValidPayment() {
      return hasRequiredFields(['userId', 'partyId', 'type', 'amount', 'paymentMode', 'date', 'createdAt']) &&
             isCreatingOwnDoc() &&
             isValidString('partyId', 1, 50) &&
             request.resource.data.type in ['in', 'out'] &&
             request.resource.data.amount is number &&
             request.resource.data.paymentMode in ['cash', 'upi', 'bank'] &&
             isValidOptionalString('partyName', 0, 100) &&
             isValidOptionalString('description', 0, 500);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser() && request.resource.data.uid == resource.data.uid;
      allow delete: if false; // Prevent accidental deletion
    }

    match /products/{productId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidProduct();
      allow update: if isDocOwner() && isValidProduct() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /parties/{partyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidParty();
      allow update: if isDocOwner() && isValidParty() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /sales/{saleId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSale();
      allow update: if isDocOwner() && isValidSale() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /expenses/{expenseId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidExpense();
      allow update: if isDocOwner() && isValidExpense() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /payments/{paymentId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidPayment();
      allow update: if isDocOwner() && isValidPayment() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
